# ============================================
#   徐汇通 (XHT) 自动化脚本 - 环境变量配置
#   请在青龙面板 -> 环境变量 中添加以下变量
#   多账号使用 & 或 换行 分隔
# ============================================

# ---------- 必填配置 ----------

# 徐汇通用户 Token（登录后从APP抓包获取）
# 获取方式：使用抓包工具(如Charles/Fiddler)打开徐汇通APP，
#          找到任意请求头中的 Authori-zation 字段值
# 多账号示例：token1&token2&token3
XHT_TOKEN=""

# 徐汇通 API 基础地址（无需修改，除非官方更换域名）
XHT_BASE_URL="https://shrmtxh.shmedia.tech"

# ---------- 通知配置（可选） ----------

# 推送渠道：支持 notify（青龙内置通知）、pushplus、serverchan、bark、telegram
# 留空则使用青龙面板默认通知，填 "none" 关闭通知
XHT_NOTIFY=""

# PushPlus Token（XHT_NOTIFY=pushplus 时生效）
XHT_PUSHPLUS_TOKEN=""

# Server酱 SendKey（XHT_NOTIFY=serverchan 时生效）
XHT_SERVERCHAN_KEY=""

# Bark 推送地址（XHT_NOTIFY=bark 时生效）
# 格式：https://api.day.app/你的key
XHT_BARK_URL=""

# Telegram Bot Token（XHT_NOTIFY=telegram 时生效）
XHT_TG_BOT_TOKEN=""

# Telegram Chat ID（XHT_NOTIFY=telegram 时生效）
XHT_TG_CHAT_ID=""

# Telegram API Proxy（可选，无需代理留空）
XHT_TG_API_PROXY=""

# ---------- 高级配置（可选） ----------

# 请求超时时间（秒），默认 15
XHT_TIMEOUT="15"

# 签到重试次数，默认 3
XHT_RETRY_COUNT="3"

# 是否模拟浏览文章（true/false），默认 true
XHT_BROWSE_ARTICLE="true"

# 模拟浏览文章数量，默认 5
XHT_BROWSE_COUNT="5"

# 是否模拟分享（true/false），默认 true
XHT_SHARE="true"

# 模拟分享次数，默认 1
XHT_SHARE_COUNT="1"