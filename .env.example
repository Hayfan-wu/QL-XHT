# ============================================
#   徐汇通 (XHT) 自动化脚本 - 环境变量配置示例
#   复制此文件为 .env 并填入实际值
# ============================================

# ---------- QQ 机器人配置（必填） ----------

# QQ 机器人 WebSocket 地址（OneBot v11 协议）
QQ_WS_URL="ws://127.0.0.1:8080"

# QQ 机器人 HTTP API 地址
QQ_HTTP_URL="http://127.0.0.1:3000"

# 管理员 QQ 号
QQ_ADMIN_QQ="10000"

# ---------- 徐汇通配置 ----------
XHT_BASE_URL="https://shrmtxh.shmedia.tech"

# ---------- 通知配置（可选） ----------
XHT_NOTIFY=""

# PushPlus Token
XHT_PUSHPLUS_TOKEN=""

# Server酱 SendKey
XHT_SERVERCHAN_KEY=""

# Bark 推送地址
XHT_BARK_URL=""

# Telegram Bot Token
XHT_TG_BOT_TOKEN=""

# Telegram Chat ID
XHT_TG_CHAT_ID=""

# Telegram API Proxy
XHT_TG_API_PROXY=""

# ---------- 高级配置（可选） ----------
XHT_TIMEOUT="15"
XHT_RETRY_COUNT="3"
XHT_BROWSE_ARTICLE="true"
XHT_BROWSE_COUNT="5"
XHT_SHARE="true"
XHT_SHARE_COUNT="1"