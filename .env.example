# ============================================
#   徐汇通 (XHT) 自动化脚本 - 环境变量配置示例
#   复制此文件为 .env 并填入实际值
# ============================================

# ---------- 青龙 Open API ----------
QL_URL="http://127.0.0.1:5700"
QL_CLIENT_ID="your_client_id"
QL_CLIENT_SECRET="your_client_secret"

# ---------- 徐汇通配置 ----------
# 业务 API 域名（真实抓包所得，一般无需修改）
XHT_BASE_URL="https://app.xuhuimedia.cn/media-basic-port"
# 设备标识，32位字符串；留空会自动生成一个稳定值
XHT_DEVICE_ID=""
# 站点 ID，徐汇通固定为 310104
XHT_SITE_ID="310104"

# ---------- 通知配置（可选） ----------
XHT_NOTIFY=""
XHT_PUSHPLUS_TOKEN=""
XHT_SERVERCHAN_KEY=""
XHT_BARK_URL=""
XHT_TG_BOT_TOKEN=""
XHT_TG_CHAT_ID=""
XHT_TG_API_PROXY=""

# ---------- 高级配置（可选） ----------
XHT_TIMEOUT="15"
XHT_RETRY_COUNT="3"
XHT_BROWSE_ARTICLE="true"
XHT_BROWSE_COUNT="5"
