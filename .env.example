# ============================================
#   徐汇通 (XHT) 纯手动部署 - 配置示例
#   复制此文件为 .env 并填入实际值
#   或直接在青龙面板「环境变量」中设置
# ============================================

# ---------- Token（必填）----------
# 环境变量名：XHT_TOKEN
# 值：你的JWT Token，多账号用 & 分隔
# 例如：XHT_TOKEN=eyJ0eXAiOiJKV1QiLCJh...&eyJ0eXAiOiJKV1...
XHT_TOKEN=

# ---------- 业务配置（可选）----------
XHT_BASE_URL=https://app.xuhuimedia.cn/media-basic-port
XHT_DEVICE_ID=
XHT_SITE_ID=310104

# ---------- 高级配置（可选）----------
XHT_TIMEOUT=15
XHT_RETRY_COUNT=3
XHT_BROWSE_ARTICLE=true
XHT_BROWSE_COUNT=5

# ---------- 通知配置（可选）----------
# XHT_NOTIFY=pushplus      # pushplus / serverchan / bark / telegram
# XHT_PUSHPLUS_TOKEN=
# XHT_SERVERCHAN_KEY=
# XHT_BARK_URL=
# XHT_TG_BOT_TOKEN=
# XHT_TG_CHAT_ID=
# XHT_TG_API_PROXY=